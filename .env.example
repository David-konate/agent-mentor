# Copie ce fichier en ".env" et remplis tes vraies valeurs.
# .env.example est un MODELE suivi par git -> JAMAIS de vraie cle ici, que des placeholders !

# Cle API Groq (gratuite) : https://console.groq.com/keys
GROQ_API_KEY=colle_ta_cle_groq_ici
GROQ_MODEL=llama-3.3-70b-versatile

# Base de donnees MySQL (MAMP en local)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=mentor_cda

# Cle de signature des sessions : mettre une valeur aleatoire
SECRET_KEY=valeur_aleatoire_a_definir
